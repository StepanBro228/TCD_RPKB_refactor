<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/prixodAccent">
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/prixodCardShadow" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item android:bottom="2dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/prixodItemBackgroundAlt" />
                    <corners android:radius="8dp" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/prixodItemBorder" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple> 