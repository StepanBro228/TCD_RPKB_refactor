<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#50FFFFFF">
    <item>
        <layer-list>
            <!-- Усиленная тень -->
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="5dp">
                <shape android:shape="rectangle">
                    <solid android:color="#50000000" />
                    <corners android:radius="28dp" />
                </shape>
            </item>
            <!-- Основной темно-синий фон -->
            <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1E3A8A" />
                    <corners android:radius="28dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple> 