<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/prixodCardShadow" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item android:bottom="2dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/prixodSurface" />
                    <corners android:radius="8dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/prixodEditTextFocused" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/prixodCardShadow" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item android:bottom="2dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/prixodSurface" />
                    <corners android:radius="8dp" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/prixodEditTextBorder" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector> 