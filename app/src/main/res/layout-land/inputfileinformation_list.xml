<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="6dp"
    android:layout_marginEnd="6dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Верхняя часть: наименование и серия -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/list_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <LinearLayout
                android:id="@+id/series_storage_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="2dp">

                <TextView
                    android:id="@+id/list_series"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:textColor="#666666"
                    android:layout_marginEnd="16dp"
                    android:visibility="gone" />
                    
                <TextView
                    android:id="@+id/sender_storage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#3F51B5"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="8dp" />

        <!-- Средняя часть: количество, единица измерения и поле ввода -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Количество: "
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/list_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="#000000" />

                <TextView
                    android:id="@+id/list_mesure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textSize="14sp"
                    android:textColor="#555555" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/edit_text_default"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Взял: "
                    android:textStyle="bold"
                    android:textColor="#E91E63"
                    android:textSize="15sp"
                    android:layout_marginStart="6dp" />

                <EditText
                    android:id="@+id/carried"
                    android:layout_width="50dp"
                    android:layout_height="35dp"
                    android:ems="4"
                    android:inputType="number"
                    android:hint="0"
                    android:gravity="center"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:importantForAutofill="no"
                    android:textAlignment="center"
                    android:imeOptions="actionDone"
                    android:background="@null"
                    android:paddingEnd="6dp"
                    android:singleLine="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="8dp" />

        <!-- Нижняя часть: остатки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Остатки:"
                android:textStyle="bold"
                android:textColor="#FF9800"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:rowCount="4">

                <!-- Первая строка -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="В ячейке:"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:layout_column="0"
                    android:layout_row="0"
                    android:layout_gravity="fill_horizontal"
                    android:layout_columnWeight="2"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/cell_balance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_column="1"
                    android:layout_row="0"
                    android:layout_gravity="fill_horizontal"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="По серии:"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:layout_column="2"
                    android:layout_row="0"
                    android:layout_gravity="fill_horizontal"
                    android:layout_columnWeight="1.5"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/series_balance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_column="3"
                    android:layout_row="0"
                    android:layout_gravity="fill_horizontal"
                    android:layout_columnWeight="1"/>

                <!-- Вторая строка -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Свободный:"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:layout_column="0"
                    android:layout_row="1"
                    android:layout_gravity="fill_horizontal"
                    android:layout_columnWeight="2"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/free_balance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_column="1"
                    android:layout_row="1"
                    android:layout_gravity="fill_horizontal"
                    android:layout_columnWeight="1"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Общий:"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:layout_column="2"
                    android:layout_row="1"
                    android:layout_gravity="fill_horizontal"
                    android:layout_columnWeight="1.5"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/total_balance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_column="3"
                    android:layout_row="1"
                    android:layout_gravity="fill_horizontal"
                    android:layout_columnWeight="1"
                    android:layout_marginTop="4dp"/>
            </GridLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>