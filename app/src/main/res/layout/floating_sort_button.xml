<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="8dp">

    <!-- Кнопка сортировки, которая всегда видна -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/sort_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:contentDescription="Сортировка"
        android:focusable="true"
        app:backgroundTint="@color/prixodPrimary"
        app:borderWidth="0dp"
        app:elevation="8dp"
        app:fabSize="normal"
        app:rippleColor="@color/prixodAccent"
        app:srcCompat="@android:drawable/ic_dialog_dialer"
        app:tint="@color/colorWhite"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Индикатор активной сортировки -->
    <View
        android:id="@+id/sort_indicator"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:background="@drawable/filter_indicator_shape"
        android:visibility="invisible"
        android:elevation="9dp"
        app:layout_constraintTop_toTopOf="@+id/sort_button"
        app:layout_constraintStart_toStartOf="@+id/sort_button"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp" />

    <!-- Контейнер для панели сортировки, который изначально скрыт -->
    <androidx.cardview.widget.CardView
        android:id="@+id/sort_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/sort_button"
        app:layout_constraintEnd_toEndOf="@+id/sort_button">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/prixod_header_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            android:minWidth="320dp">

            <TextView
                android:id="@+id/header_name"
                style="@style/PrixodHeaderCompactTextStyle"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Наимен."
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:drawablePadding="2dp"
                android:background="?attr/selectableItemBackground"/>

            <TextView
                android:id="@+id/header_measure"
                style="@style/PrixodHeaderCompactTextStyle"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Ед. изм."
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:drawablePadding="2dp"
                android:background="?attr/selectableItemBackground"/>

            <TextView
                android:id="@+id/header_storage"
                style="@style/PrixodHeaderCompactTextStyle"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Ячейка"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:drawablePadding="2dp"
                android:background="?attr/selectableItemBackground"/>

            <TextView
                android:id="@+id/header_amount"
                style="@style/PrixodHeaderCompactTextStyle"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Кол-во"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:drawablePadding="4dp"
                android:background="?attr/selectableItemBackground"/>

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:minWidth="48dp">
                
                <ImageButton
                    android:id="@+id/header_clear_sort"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="12dp"
                    android:layout_gravity="center_vertical|end"
                    android:src="@drawable/ic_clear_sort"
                    android:contentDescription="Очистить сортировку" />
            </FrameLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout> 