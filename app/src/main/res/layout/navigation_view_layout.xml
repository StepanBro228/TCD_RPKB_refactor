<com.google.android.material.navigation.NavigationView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/navigation_view"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:background="@android:color/transparent"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:defaultFocusHighlightEnabled="false"
    android:stateListAnimator="@null"
    app:elevation="0dp"
    app:itemIconTint="@null"
    app:itemTextColor="@null"
    app:headerLayout="@null"
    android:paddingBottom="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:defaultFocusHighlightEnabled="false"
        android:background="@android:color/white">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/filter_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:background="@android:color/white"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:defaultFocusHighlightEnabled="false"
            android:isScrollContainer="true"
            android:fadeScrollbars="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:defaultFocusHighlightEnabled="false"
                android:background="@android:color/white">

                <!-- Шапка Navigation View -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/nav_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="@drawable/combined_nav_header_background">

                    <!-- Карточка пользователя -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/user_name_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:background="@drawable/user_info_gradient">

                            <ImageView
                                android:id="@+id/user_avatar"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circular_avatar_border"
                                android:contentDescription="Аватар пользователя"
                                android:padding="2dp"
                                android:scaleType="fitCenter"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent" />

                            <TextView
                                android:id="@+id/user_full_name"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_marginEnd="8dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="Петров Сергей А."
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toTopOf="@+id/user_role"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/user_avatar"
                                app:layout_constraintTop_toTopOf="@+id/user_avatar"
                                app:layout_constraintVertical_chainStyle="packed" />

                            <TextView
                                android:id="@+id/user_role"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/user_role_badge"
                                android:paddingStart="10dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="2dp"
                                android:text="Менеджер"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="@+id/user_avatar"
                                app:layout_constraintStart_toEndOf="@+id/user_avatar"
                                app:layout_constraintTop_toBottomOf="@+id/user_full_name" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </androidx.cardview.widget.CardView>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Разделитель -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/prixodItemBorder"
                    android:alpha="0.3" />

                <!-- Контент фильтров -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Заголовок фильтров -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Фильтры"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/prixodTextSecondary"
                        android:layout_marginBottom="5dp" />

                    <!-- Чекбоксы в одну строку -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <CheckBox
                            android:id="@+id/filter_cps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="ЦПС"
                            android:textSize="14sp"
                            android:layout_marginEnd="25dp"
                            android:textColor="@color/prixodTextSecondary" />

                        <CheckBox
                            android:id="@+id/filter_availability"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="Доступность"
                            android:textSize="14sp"
                            android:textColor="@color/prixodTextSecondary" />
                    </LinearLayout>

                    <!-- Отправитель -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Отправитель:"
                            android:textSize="14sp"
                            android:textColor="@color/prixodTextSecondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <EditText
                                android:id="@+id/filter_sender"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/filter_edittext_background"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:hint="Введите отправителя"
                                android:textSize="14sp"
                                android:singleLine="true"
                                android:imeOptions="actionNext"
                                android:nextFocusDown="@+id/filter_movement_number" />

                            <ImageButton
                                android:id="@+id/clear_sender"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_close_clear_cancel"
                                android:contentDescription="Очистить" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Номер перемещения -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Номер перемещения:"
                            android:textSize="14sp"
                            android:textColor="@color/prixodTextSecondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <EditText
                                android:id="@+id/filter_movement_number"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/filter_edittext_background"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:hint="Введите номер"
                                android:textSize="14sp"
                                android:singleLine="true"
                                android:inputType="number"
                                android:focusable="true"
                                android:focusableInTouchMode="true"
                                android:clickable="true"
                                android:imeOptions="actionNext"
                                android:nextFocusDown="@+id/filter_nomenculature" />

                            <ImageButton
                                android:id="@+id/clear_movement_number"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_close_clear_cancel"
                                android:contentDescription="Очистить" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Номенкулатура -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Номенкулатура: "
                            android:textSize="14sp"
                            android:textColor="@color/prixodTextSecondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <EditText
                                android:id="@+id/filter_nomenculature"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/filter_edittext_background"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:hint="Введите номенкулатуру"
                                android:textSize="14sp"
                                android:singleLine="true"
                                android:imeOptions="actionNext"
                                android:nextFocusDown="@+id/filter_series" />

                            <ImageButton
                                android:id="@+id/clear_nomenculature"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_close_clear_cancel"
                                android:contentDescription="Очистить" />
                        </LinearLayout>
                    </LinearLayout>


                    <!-- Серия -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Серия:"
                            android:textSize="14sp"
                            android:textColor="@color/prixodTextSecondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <EditText
                                android:id="@+id/filter_series"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/filter_edittext_background"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:hint="Введите серию"
                                android:inputType="number"
                                android:textSize="14sp"
                                android:singleLine="true"
                                android:imeOptions="actionNext"
                                android:nextFocusDown="@+id/filter_recipient" />

                            <ImageButton
                                android:id="@+id/clear_series"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_close_clear_cancel"
                                android:contentDescription="Очистить" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Получатель -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Получатель:"
                            android:textSize="14sp"
                            android:textColor="@color/prixodTextSecondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <EditText
                                android:id="@+id/filter_recipient"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/filter_edittext_background"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:hint="Введите получателя"
                                android:textSize="14sp"
                                android:singleLine="true"
                                android:imeOptions="actionNext"
                                android:nextFocusDown="@+id/filter_assembler" />

                            <ImageButton
                                android:id="@+id/clear_recipient"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_close_clear_cancel"
                                android:contentDescription="Очистить" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Комплектует -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Комплектует:"
                            android:textSize="14sp"
                            android:textColor="@color/prixodTextSecondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <EditText
                                android:id="@+id/filter_assembler"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/filter_edittext_background"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:hint="Введите комплектовщика"
                                android:textSize="14sp"
                                android:singleLine="true"
                                android:imeOptions="actionNext"
                                android:nextFocusDown="@+id/filter_priority" />

                            <ImageButton
                                android:id="@+id/clear_assembler"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_close_clear_cancel"
                                android:contentDescription="Очистить" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Приоритет -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Приоритет:"
                            android:textSize="14sp"
                            android:textColor="@color/prixodTextSecondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <Spinner
                                android:id="@+id/filter_priority"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                style="@style/FilterSpinnerStyle"
                                android:spinnerMode="dropdown"
                                android:popupBackground="@android:color/white"
                                android:dropDownVerticalOffset="1dp"
                                android:nextFocusDown="@+id/filter_receiver" />

                            <ImageButton
                                android:id="@+id/clear_priority"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_close_clear_cancel"
                                android:contentDescription="Очистить" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Получает -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="24dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Получает:"
                            android:textSize="14sp"
                            android:textColor="@color/prixodTextSecondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <EditText
                                android:id="@+id/filter_receiver"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:background="@drawable/filter_edittext_background"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:hint="Введите получателя"
                                android:textSize="14sp"
                                android:singleLine="true"
                                android:imeOptions="actionDone" />

                            <ImageButton
                                android:id="@+id/clear_receiver"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_close_clear_cancel"
                                android:contentDescription="Очистить" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Кнопки действий -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="36dp">

                        <!-- Кнопка "Применить фильтры" -->
                        <TextView
                            android:id="@+id/btn_apply_filters"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/apply_button_background"
                            android:text="ПРИМЕНИТЬ ФИЛЬТРЫ"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginBottom="8dp"
                            android:foreground="?android:attr/selectableItemBackground" />

                        <!-- Кнопка "Установить по умолчанию" -->
                        <TextView
                            android:id="@+id/btn_set_default_filters"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/default_button_background"
                            android:text="СОХРАНИТЬ ФИЛЬТРЫ ПО УМОЛЧАНИЮ"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginBottom="8dp"
                            android:foreground="?android:attr/selectableItemBackground" />

                        <!-- Кнопка "Сбросить фильтры" -->
                        <TextView
                            android:id="@+id/btn_reset_filters"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/reset_button_background"
                            android:text="СБРОСИТЬ ФИЛЬТРЫ"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackground" />
                    </LinearLayout>

                    <!-- Пустое пространство в конце для предотвращения проблем с прокруткой -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@android:color/white" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>
</com.google.android.material.navigation.NavigationView> 