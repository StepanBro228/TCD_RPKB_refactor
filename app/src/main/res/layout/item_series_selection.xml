<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="1dp"
    android:layout_marginVertical="1dp"
    app:cardCornerRadius="6dp"
    app:cardElevation="4dp"
    app:contentPadding="0dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardUseCompatPadding="false"
    app:strokeWidth="3dp"
    app:strokeColor="#666666">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:orientation="horizontal"
        android:padding="6dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">

        <!-- Серия -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="vertical">
            
            <TextView
                android:id="@+id/tv_series_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="@color/colorText"
                android:textStyle="bold"
                android:textSize="12sp"
                tools:text="Серия123456789" />
        </LinearLayout>

        <!-- Срок годности -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:orientation="vertical"
            android:layout_marginStart="4dp">
            
            <TextView
                android:id="@+id/tv_expiry_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/colorText"
                android:textSize="14sp"
                tools:text="31.12.2023" />
        </LinearLayout>

        <!-- Свободный остаток -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">
            
            <TextView
                android:id="@+id/tv_free_balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/colorSuccess"
                android:textStyle="bold"
                android:textSize="14sp"
                tools:text="50.0" />
        </LinearLayout>

        <!-- Резерв других ЗНП -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">
            
            <TextView
                android:id="@+id/tv_reserved_by_others"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/colorWarning"
                android:textSize="14sp"
                tools:text="10.0" />
        </LinearLayout>

        <!-- Количество в документе -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">
            
            <TextView
                android:id="@+id/tv_allocated_quantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                android:textSize="14sp"
                tools:text="45.0" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView> 