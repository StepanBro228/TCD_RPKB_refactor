<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_elegant"
    tools:context=".UI.main.activity.MainActivity">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.823">

        <Button
            android:id="@+id/button_main_lc"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="30dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="15dp"
            android:backgroundTint="@color/colorPrimary"
            android:onClick="goTolc"
            android:text="ЛЦ"
            android:textSize="18sp"
            app:strokeColor="@color/colorPrimaryDark"
            app:strokeWidth="3dp" />

        <Button
            android:id="@+id/button_main_lvc"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="30dp"
            android:backgroundTint="@color/colorPrimary"
            android:onClick="goTolvk"
            android:text="ЛВК"
            android:textSize="18sp"
            app:strokeColor="@color/colorPrimaryDark"
            app:strokeWidth="3dp" />

        <Button
            android:id="@+id/button_main_sp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="30dp"
            android:layout_marginVertical="15dp"
            android:backgroundTint="@color/colorPrimary"
            android:onClick="goTosp"
            android:text="СП"
            android:textSize="18sp"
            app:strokeColor="@color/colorPrimaryDark"
            app:strokeWidth="3dp" />
    </LinearLayout>

    <!-- Кнопка авторизации (по центру экрана для неавторизованных пользователей) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/auth_button_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:backgroundTint="@color/colorPrimary"
        android:elevation="8dp"
        android:paddingHorizontal="32dp"
        android:paddingVertical="12dp"
        android:text="Авторизация"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/colorPrimaryDark"
        app:strokeWidth="2dp"
        tools:visibility="visible" />

    <!-- Кнопка авторизации (в углу для авторизованных пользователей) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/auth_button_corner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Авторизация"
        android:visibility="gone"
        app:backgroundTint="@color/colorPrimary"
        app:fabCustomSize="65dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/ic_lock_idle_lock"
        app:tint="@android:color/white"
        tools:visibility="visible" />

    <!-- Кнопка настроек в правом верхнем углу -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/settings_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:fabCustomSize="65dp"
        android:layout_margin="16dp"
        app:iconSize = "40dp"
        android:contentDescription="Настройки подключения"
        app:backgroundTint="@color/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/ic_menu_manage"
        app:tint="@android:color/white" />

    <TextView
        android:id="@+id/textView1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>