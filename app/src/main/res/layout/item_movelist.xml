<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/item_move_ripple"
    android:stateListAnimator="@animator/card_elevation_animator">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/priorityIndicator"
            android:layout_width="12dp"
            android:layout_height="match_parent"
            android:background="#FF0000" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="05.02.2025 14:44:11"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="R.25.1963"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvFromWarehouse"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:paddingEnd="10dp"
                    android:layout_weight="1"
                    android:text="Склад СП"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvToWarehouse"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Склад комплектации СП"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAssembler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Имя комплектовщика"
                android:textSize="12sp"
                android:textStyle="italic"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvProduct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Модуль дисплейного процессора МДП-12 КМИВ.467451.059"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvPositionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="поз: "
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPositionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvItemsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="шт: "
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvItemsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvResponsible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Демина Ольга Владимировна"
                android:textSize="12sp"
                android:textStyle="italic" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/checkBoxes_proveden_move"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            android:layout_marginTop="4dp"
            android:orientation="vertical">

            <!-- Checkbox "Проведен" в самом верху -->
            <CheckBox
                android:id="@+id/checkboxCompleted"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center_horizontal"
                android:button="@null"
                android:clickable="false"
                android:focusable="false"
                android:gravity="center"
                android:textAlignment="center" />

            <!-- Spacer для центрирования checkboxMove -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Checkbox выбора в центре -->
        <com.step.tcd_rpkb.views.CustomCheckBox
            android:id="@+id/checkboxMove"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal" />

            <!-- Spacer для центрирования checkboxMove -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView> 