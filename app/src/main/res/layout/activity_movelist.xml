<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:defaultFocusHighlightEnabled="false"
    tools:context=".UI.movelist.activity.MoveListActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:defaultFocusHighlightEnabled="false">

        <androidx.cardview.widget.CardView
            android:id="@+id/segment_control_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="3dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/segment_control"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:orientation="horizontal"
                android:background="@color/prixodItemBorder"
                android:padding="2dp">

                <TextView
                    android:id="@+id/segment_formirovano"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/segment_ripple_effect"
                    android:gravity="center"
                    android:text="Сформированно"
                    android:textColor="@drawable/segment_text_color_selector"
                    android:textSize="10.5sp"
                    android:textAllCaps="true"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="false" />

                <TextView
                    android:id="@+id/segment_komplektuetsa"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/segment_ripple_effect"
                    android:gravity="center"
                    android:text="Комплектуется"
                    android:textColor="@drawable/segment_text_color_selector"
                    android:textSize="10.5sp"
                    android:textAllCaps="true"
                    android:clickable="true"
                    android:textStyle="bold"
                    android:focusable="false" />
                    
                <TextView
                    android:id="@+id/segment_podgotovlen"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/segment_ripple_effect"
                    android:gravity="center"
                    android:text="Подготовленно"
                    android:textColor="@drawable/segment_text_color_selector"
                    android:textSize="10.5sp"
                    android:textAllCaps="true"
                    android:clickable="true"
                    android:textStyle="bold"
                    android:focusable="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <FrameLayout
            android:id="@+id/priority_stats_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            app:layout_constraintTop_toBottomOf="@+id/segment_control_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <LinearLayout
                android:id="@+id/priority_stats_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>
                
        </FrameLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="1dp"
            android:focusable="false"
            android:focusableInTouchMode="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/priority_stats_container"
            app:layout_constraintVertical_bias="1.0"
            tools:layout_editor_absoluteX="16dp"
            />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/nav_menu_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:contentDescription="Меню"
            android:focusable="true"
            android:defaultFocusHighlightEnabled="false"
            android:stateListAnimator="@null"
            app:backgroundTint="@color/fab_no_focus_tint"
            app:borderWidth="0dp"
            app:elevation="8dp"
            app:fabSize="normal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:rippleColor="@color/fab_ripple_control"
            app:srcCompat="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/colorWhite" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/refresh_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:contentDescription="Обновить"
            android:focusable="true"
            android:visibility="gone"
            app:backgroundTint="@color/prixodPrimary"
            app:borderWidth="0dp"
            app:elevation="8dp"
            app:fabSize="normal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:rippleColor="@color/prixodAccent"
            app:srcCompat="@android:drawable/ic_popup_sync"
            app:tint="@color/colorWhite" />

        <!-- Индикатор активности фильтров (метка) -->
        <View
            android:id="@+id/filter_indicator"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="-15dp"
            android:background="@drawable/filter_indicator_shape"
            android:elevation="12dp"
            android:visibility="invisible"
            app:layout_constraintBottom_toTopOf="@+id/nav_menu_button"
            app:layout_constraintEnd_toEndOf="@+id/nav_menu_button" />

        <!-- Панель для кнопок действий выбранных элементов -->
        <androidx.cardview.widget.CardView
            android:id="@+id/actionButtonsPanel"
            android:layout_width="402dp"
            android:layout_height="107dp"
            android:layout_margin="4dp"
            android:visibility="gone"
            app:cardCornerRadius="6dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingTop="6dp"
                android:paddingEnd="4dp"
                android:paddingBottom="6dp">

                <LinearLayout
                    android:id="@+id/actionButtonsFirstRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/selectedItemsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:gravity="center_vertical"
                        android:text="Выбрано: 0"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <Button
                        android:id="@+id/btnCancelSelection"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginEnd="10dp"
                        android:backgroundTint="@color/prixodItemBorder"
                        android:minWidth="75dp"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="4dp"
                        android:text="Отмена"
                        android:textAllCaps="false"
                        android:textColor="@android:color/black"
                        android:textSize="13sp" />


                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionButtonsSecondRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:visibility="visible">


                    <Button
                        android:id="@+id/btnMoveFromWork"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:backgroundTint="@color/prixodPrimary"
                        android:minWidth="110dp"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="4dp"
                        android:text='Отпр. в \n "Сформированно"'
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <Button
                        android:id="@+id/btnMoveToWork"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginEnd="10dp"
                        android:backgroundTint="@color/prixodPrimary"
                        android:minWidth="110dp"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="4dp"
                        android:text='Отпр. в "Комплектуется"'
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:visibility="visible" />


                    <Button
                        android:id="@+id/btnFinishWork"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:backgroundTint="@color/prixodAccent"
                        android:minWidth="110dp"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="4dp"
                        android:text='Отпр. в \n "Подготовленно"'
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <Space
                        android:id="@+id/secondRow_space"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include layout="@layout/navigation_view_layout" />
</androidx.drawerlayout.widget.DrawerLayout>