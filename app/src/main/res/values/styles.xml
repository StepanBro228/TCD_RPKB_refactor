<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Стиль для заголовков групп в ExpandableListView -->
    <style name="ExpandableListGroupStyle">
        <item name="android:background">@drawable/expandable_group_background</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Стиль для дочерних элементов в ExpandableListView -->
    <style name="ExpandableListChildStyle">
        <item name="android:background">@drawable/expandable_child_background</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Стиль для самого ExpandableListView без индикатора слева -->
    <style name="NoIndicatorExpandableListView">
        <item name="android:groupIndicator">@null</item>
        <item name="android:divider">@color/colorDivider</item>
        <item name="android:dividerHeight">6dp</item>
        <item name="android:childDivider">@color/colorDivider</item>
        <item name="android:background">@color/colorSurface</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Стиль для текстовых полей в фильтрах -->
    <style name="FilterEditTextStyle">
        <item name="android:background">@drawable/edit_text_background</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Стиль для текстовых меток в фильтрах -->
    <style name="FilterTextViewStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
    </style>

    <!-- Стиль для кнопок в фильтрах -->
    <style name="FilterButtonStyle">
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:gravity">center</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Стиль для чекбоксов -->
    <style name="CustomCheckboxStyle" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:button">@drawable/custom_checkbox</item>
    </style>
    
    <!-- Новые стили для Prixod -->
    <style name="PrixodHeaderTextStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:shadowColor">@color/prixodPrimaryDark</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
        <item name="android:letterSpacing">0.03</item>
    </style>
    
    <!-- Компактный стиль для заголовков на маленьком экране -->
    <style name="PrixodHeaderCompactTextStyle" parent="PrixodHeaderTextStyle">
        <item name="android:textSize">12sp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">2</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
    </style>
    
    <style name="PrixodItemTextStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/prixodText</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:gravity">center</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">2</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
    </style>
    
    <!-- Компактный стиль для элементов списка на маленьком экране -->
    <style name="PrixodItemCompactTextStyle" parent="PrixodItemTextStyle">
        <item name="android:textSize">12sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="android:gravity">start|center_vertical</item>
    </style>
    
    <!-- Компактный стиль для поля ввода на маленьком экране -->
    <style name="PrixodEditTextCompactStyle" parent="PrixodEditTextStyle">
        <item name="android:textSize">12sp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:minHeight">32dp</item>
    </style>
    
    <style name="PrixodButtonStyle">
        <item name="android:background">@drawable/prixod_button_background</item>
        <item name="android:textColor">@color/prixodButtonText</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:elevation">6dp</item>
        <item name="android:stateListAnimator">@animator/button_state_list_animator</item>
    </style>
    
    <style name="PrixodEditTextStyle">
        <item name="android:background">@drawable/prixod_edit_text_background</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/prixodText</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:elevation">2dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColorHint">@color/prixodTextSecondary</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- Стиль для диалогового окна с анимацией -->
    <style name="PrixodDialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>
    
    <!-- Стиль для элементов бокового меню NavigationView -->
    <style name="PrixodNavigationViewStyle">
        <item name="android:background">@drawable/nav_view_background</item>
        <item name="android:elevation">8dp</item>
        <item name="android:layout_width">280dp</item>
    </style>
    
    <!-- Стиль для заголовка NavigationView -->
    <style name="PrixodNavigationHeaderStyle">
        <item name="android:background">@drawable/nav_header_background</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Стиль для адаптации к экрану RUGLINE RT41 (480x800, 240dpi) -->
    <style name="RuglineRT41_Adaptation">
        <item name="android:textSize">14sp</item>
        <item name="android:padding">8dp</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <!-- Базовый стиль для кнопок -->
    <style name="ButtonStyle">
        <item name="android:minHeight">52dp</item>
        <item name="android:minWidth">140dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:padding">10dp</item>
    </style>

    <!-- Адаптация кнопок для RUGLINE RT41 -->
    <style name="ButtonStyle.RuglineRT41">
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">120dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="textAllCaps">false</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#3F51B5</item>
        <item name="colorPrimaryDark">#303F9F</item>
        <item name="colorAccent">#FF4081</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="SplashTheme" parent="AppTheme">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="FilterSpinnerStyle" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@drawable/filter_edittext_background</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/prixodTextSecondary</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <style name="FilterActionButtonStyle">
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:gravity">center</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Стиль для современных кнопок -->
    <style name="ModernButton" parent="Widget.MaterialComponents.Button">
        <item name="android:stateListAnimator">@drawable/button_state_list_animator</item>
        <item name="android:elevation">4dp</item>
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="cornerRadius">24dp</item>
        <item name="rippleColor">#80FFFFFF</item>
        <item name="android:minHeight">52dp</item>
    </style>
    
    <!-- Стиль для основной кнопки -->
    <style name="ModernButton.Primary">
        <item name="backgroundTint">@null</item>
        <item name="background">@drawable/primary_button_background</item>
    </style>
    
    <!-- Стиль для вторичной кнопки -->
    <style name="ModernButton.Secondary">
        <item name="backgroundTint">@null</item>
        <item name="background">@drawable/secondary_button_background</item>
    </style>
</resources> 